# Copy selected entries into local files ignored by git:
#   .env.ai-review.local
#   .env.ai-review.openai.local
#   .env.ai-review.siliconflow.local
#
# Load order:
# 1. shell env vars
# 2. .env.ai-review.local
# 3. .env.ai-review.<provider>.local
#
# Shell env vars always win over local files.

# Common defaults (.env.ai-review.local)
AI_REVIEW_MODE=on
AI_REVIEW_PROVIDER=siliconflow

# OpenAI profile (.env.ai-review.openai.local)
# AI_REVIEW_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=replace_with_your_openai_key

# SiliconFlow profile (.env.ai-review.siliconflow.local)
# AI_REVIEW_MODEL=Pro/MiniMaxAI/MiniMax-M2.5
# AI_REVIEW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_API_KEY=replace_with_your_siliconflow_key
